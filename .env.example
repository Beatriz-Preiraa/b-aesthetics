# ─── B.aesthetics — Variáveis de Ambiente ───────────────────────────────────

# Banco de dados SQLite (arquivo local, ótimo para desenvolvimento e MVPs)
DATABASE_URL="file:./dev.db"

# JWT Secret (gere com: openssl rand -base64 64)
JWT_SECRET="troque-por-uma-chave-segura-em-producao"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="B.aesthetics"

# Opcional: Upload de imagens (ex: Cloudinary)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# Opcional: E-mail (ex: Resend)
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@b-aesthetics.app"
